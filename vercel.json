{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/rss",
      "dest": "pages/api/rss.js"
    },
    {
      "src": "/api/atom",
      "dest": "pages/api/atom.js"
    },
    {
      "src": "/",
      "dest": "pages/index.js"
    }
  ]
}